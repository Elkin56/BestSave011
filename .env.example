# Скопируйте в настройки Vercel (Environment Variables), не коммитьте реальные значения
BOT_TOKEN=123456:ABC-ваш-токен-от-BotFather
DATABASE_URL=postgresql://user:pass@host/db?sslmode=require
WEBHOOK_SECRET=любая-случайная-строка

# ── Условия доступа (гейт) ──
# Канал сообщества. Бот ОБЯЗАН быть его администратором — иначе
# getChatMember не ответит и подписка у всех повиснет в «не удалось проверить».
COMMUNITY_CHAT=@bestsavee
COMMUNITY_TITLE=BestSave Community
# Нужно только для приватного канала: инвайт-ссылка, т.к. числовой id не открыть
# COMMUNITY_URL=https://t.me/+xxxxxxxx
# Сколько друзей нужно привести до открытия доступа
REQUIRED_INVITES=3

# Владельцы продукта: список tg id через запятую. Гейт на них не действует.
ADMIN_TG_IDS=
